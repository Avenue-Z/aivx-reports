# Copy this file to .env and fill in your values.
# Never commit .env to GitHub.

# Peec API key — found in your Peec account settings
PEEC_API_KEY=your_peec_api_key_here

# Peec project/workspace ID — the workspace you want to run the report against
# Only needed for the live API path. For CSV path, this is not required.
PEEC_PROJECT_ID=your_project_id_here
